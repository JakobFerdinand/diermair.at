---
import { getCollection } from 'astro:content';
import { Axe, Trees, MessageSquare, Crosshair } from '@lucide/astro';

const iconMap = { MessageSquare, Axe, Crosshair, Trees } as const;

const leistungen = (await getCollection('leistungen')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="leistungen">
    <h2>Leistungen</h2>
    <div class="leistungen-grid">
        {leistungen.map((leistung) => {
            const Icon = iconMap[leistung.data.icon];
            return (
                <a href={`/leistungen/${leistung.id}`} class="leistung-card card">
                    <div class="leistung-title">
                        <Icon width={32} height={32} />
                        <h3>{leistung.data.title}</h3>
                    </div>
                    <p>{leistung.data.teaser}</p>
                    <span class="mehr-link">Mehr erfahren</span>
                </a>
            );
        })}
    </div>
</section>

<style>
  #leistungen {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #leistungen .leistungen-grid {
    width: 100%;
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .leistung-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: opacity 0.5s ease-out, transform 0.5s ease-out, box-shadow 0.2s ease;
  }

  .leistung-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .leistung-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .leistung-title h3 {
    margin: 0;
  }

  .mehr-link {
    display: inline-block;
    margin-top: auto;
    padding-top: 0.75rem;
    font-weight: bold;
    color: var(--green-color);
  }

  .leistung-card:hover .mehr-link {
    text-decoration: underline;
  }

  @media (max-width: 639px) {
    .leistung-card {
      width: 100%;
    }
  }
</style>
