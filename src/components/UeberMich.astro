---
import { Image } from "astro:assets";
import ProfilePicture from '../images/paul.jpeg';
import UeberMichText from '../data/ueber-mich.md';
---
<section id="ueber-mich" class="card">
  <div class="card-content">
    <Image
      src={ProfilePicture}
      class="portrait"
      alt="Paul Diermair"
    />

    <div class="text-content">
      <h2>Paul Diermair</h2>
      <h3>Forstwart & Forstwirtschaftsmeister</h3>
      <div class="ueber-text">
        <UeberMichText />
      </div>
    </div>
  </div>
</section>

<style>
  /* Card-Container */
  #ueber-mich.card {
    max-width: 40rem;
    margin: 2rem auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Inhalt wrapper für flexibles Layout */
  .card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Profilbild */
  .portrait {
    width: 10rem;
    height: 10rem;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    border: 4px solid var(--green-color);
  }

  /* Textbereich */
  .text-content h2 {
    font-size: 2rem;
    margin: 0;
    color: var(--green-color);
  }

  .text-content h3 {
    font-size: 1.25rem;
    margin: 0.5rem 0 1rem;
    color: var(--green-color);
    font-weight: 500;
  }

  .ueber-text {
    max-width: 30rem;
    line-height: 1.6;
    color: #333;
  }

  .ueber-text :global(p) {
    margin: 0;
  }

  .ueber-text :global(a) {
    color: var(--green-color);
    text-decoration: none;
    border-bottom: 1px dotted currentColor;
  }

  /* Desktop: zweispaltig */
  @media (min-width: 768px) {
    #ueber-mich.card .card-content {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
    }
    .portrait {
      margin-right: 2rem;
      margin-bottom: 0;
    }
  }
</style>
